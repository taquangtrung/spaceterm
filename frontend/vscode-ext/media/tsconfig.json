{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@spaceterm/block-renderer": ["../../block-renderer/src/index.ts"],
      "@spaceterm/rich-renderers": ["../../rich-renderers/src/index.ts"]
    }
  },
  "include": ["."]
}
